# Copy this file to .env and adjust values as needed.
# All variables are optional — defaults work out of the box.

# Path to the directory containing the source CSV
INGESTION_RAW_DATA_DIR=rawData

# Source CSV filename
INGESTION_SOURCE_FILE=edifices_patrimoine.csv

# Root directory for pipeline stage outputs (Parquet, JSONL)
INGESTION_DATA_DIR=data

# Pipeline version stamped on every ingested row
INGESTION_PIPELINE_VERSION=0.2.0

# Logging level: DEBUG | INFO | WARNING | ERROR
INGESTION_LOG_LEVEL=INFO

# Log format: dev (colored, human-readable) | json (structured, for CI/prod)
INGESTION_LOG_FORMAT=dev
